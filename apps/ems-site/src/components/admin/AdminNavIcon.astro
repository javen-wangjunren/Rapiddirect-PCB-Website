---
export interface Props {
  name: 'pages' | 'media' | 'layout' | 'external';
  class?: string;
}

const { name, class: className = '' } = Astro.props;
---

<span class={`inline-flex h-4 w-4 items-center justify-center ${className}`} aria-hidden="true">
  {name === 'pages' ? (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
      <rect x="4" y="4" width="6" height="6" rx="1.5"></rect>
      <rect x="14" y="4" width="6" height="6" rx="1.5"></rect>
      <rect x="4" y="14" width="6" height="6" rx="1.5"></rect>
      <rect x="14" y="14" width="6" height="6" rx="1.5"></rect>
    </svg>
  ) : null}

  {name === 'media' ? (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
      <rect x="3.5" y="5" width="17" height="14" rx="2"></rect>
      <circle cx="9" cy="10" r="1.5"></circle>
      <path d="M6 16l4-4 3 3 2-2 3 3"></path>
    </svg>
  ) : null}

  {name === 'layout' ? (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
      <rect x="3.5" y="4" width="17" height="16" rx="2"></rect>
      <path d="M3.5 9.5h17"></path>
      <path d="M9 9.5V20"></path>
    </svg>
  ) : null}

  {name === 'external' ? (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
      <path d="M14 5h5v5"></path>
      <path d="M10 14L19 5"></path>
      <path d="M19 13v4a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h4"></path>
    </svg>
  ) : null}
</span>
