---
import { getAssetPath } from '../../lib/assets';

export interface Props {
  data: {
    title: string;
    background_image_url?: string;
    benefits: Array<{ title: string; description: string }>;
    benefit_conclusion: string;
    cta: { href: string; label: string };
  };
}

const { data } = Astro.props;

const backgroundImageUrl = data.background_image_url
  ? getAssetPath(data.background_image_url)
  : undefined;
---

<section class="relative overflow-hidden">
  <div
    class="absolute inset-0 bg-slate-100"
    style={
      backgroundImageUrl
        ? { backgroundImage: `url(${backgroundImageUrl})`, backgroundSize: 'cover', backgroundPosition: 'center' }
        : undefined
    }
  />
  {!data.background_image_url && (
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-slate-100 to-slate-200" />
  )}

  <div class="relative mx-auto max-w-7xl px-6 py-16 sm:py-20">
    <div class="max-w-xl rounded-3xl border border-white/50 bg-white/30 p-8 shadow-[0_20px_60px_-30px_rgba(0,0,0,0.45)] sm:p-10">
      <h1 class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">
        {data.title}
      </h1>

      <div class="mt-8 space-y-6">
        {data.benefits.map((item) => (
          <div class="flex items-start gap-4">
            <div class="mt-1 flex h-10 w-10 items-center justify-center rounded-lg bg-[#ea543f]/20 text-[#ea543f]">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2l3 7 7 3-7 3-3 7-3-7-7-3 7-3 3-7z" />
              </svg>
            </div>
            <div class="min-w-0">
              <p class="text-base font-semibold leading-6 text-slate-900">{item.title}</p>
              <p class="mt-1 text-sm leading-6 text-slate-600">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-8 border-t border-slate-200/80 pt-6">
        <p class="text-sm leading-6 text-slate-700">{data.benefit_conclusion}</p>
        <div class="mt-6">
          <a
            href={data.cta.href}
            class="inline-flex items-center justify-center rounded-xl bg-[#ea543f] px-6 py-4 text-base font-bold text-white shadow-sm transition hover:bg-[#d84c39] focus:outline-none focus:ring-2 focus:ring-[#ea543f]/50 focus:ring-offset-2"
          >
            {data.cta.label}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
