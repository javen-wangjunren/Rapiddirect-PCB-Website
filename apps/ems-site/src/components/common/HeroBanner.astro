---
import { getAssetPath, getSupabaseImageUrl } from '../../lib/assets';

export interface Props {
  data: {
    title: string;
    background_image_url?: string;
    benefits: Array<{ title: string; description: string }>;
    benefit_conclusion: string;
    cta: { href: string; label: string };
  };
}

const { data } = Astro.props;

const backgroundImageUrl = data.background_image_url ? getAssetPath(data.background_image_url) : undefined;
const backgroundImageSrc = data.background_image_url ?? '';

const heroSrc600 = backgroundImageSrc ? getSupabaseImageUrl(backgroundImageSrc, { width: 600, quality: 75 }) : '';
const heroSrc900 = backgroundImageSrc ? getSupabaseImageUrl(backgroundImageSrc, { width: 900, quality: 75 }) : '';
const heroSrc1200 = backgroundImageSrc ? getSupabaseImageUrl(backgroundImageSrc, { width: 1200, quality: 75 }) : '';
const heroSrc1600 = backgroundImageSrc ? getSupabaseImageUrl(backgroundImageSrc, { width: 1600, quality: 80 }) : '';
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-slate-100" />
  {backgroundImageUrl && (
    <img
      src={heroSrc900}
      srcset={`${heroSrc600} 600w, ${heroSrc900} 900w, ${heroSrc1200} 1200w, ${heroSrc1600} 1600w`}
      sizes="100vw"
      alt=""
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  )}
  {!data.background_image_url && (
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-slate-100 to-slate-200" />
  )}

  <div class="relative mx-auto max-w-7xl px-6 py-16 sm:py-20">
    <div class="max-w-xl rounded-3xl border border-white/50 bg-white/95 p-6 shadow-[0_20px_60px_-30px_rgba(0,0,0,0.45)] sm:p-10">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-5xl">
        {data.title}
      </h1>

      <div class="mt-6 space-y-4 sm:mt-8 sm:space-y-6">
        {data.benefits.map((item) => (
          <div class="flex items-start gap-4">
            <div class="mt-1 flex h-9 w-9 items-center justify-center rounded-lg bg-[#ea543f]/20 text-[#ea543f] sm:h-10 sm:w-10">
              <svg viewBox="0 0 24 24" class="h-4 w-4 sm:h-5 sm:w-5" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2l3 7 7 3-7 3-3 7-3-7-7-3 7-3 3-7z" />
              </svg>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-semibold leading-6 text-slate-900 sm:text-base">{item.title}</p>
              <p class="mt-1 text-xs leading-5 text-slate-600 sm:text-sm sm:leading-6">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-6 border-t border-slate-200/80 pt-4 sm:mt-8 sm:pt-6">
        <p class="text-sm leading-6 text-slate-700">{data.benefit_conclusion}</p>
        <div class="mt-5 sm:mt-6">
          <a
            href={data.cta.href}
            class="inline-flex items-center justify-center rounded-xl bg-[#ea543f] px-5 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-[#d84c39] focus:outline-none focus:ring-2 focus:ring-[#ea543f]/50 focus:ring-offset-2 sm:px-6 sm:py-4 sm:text-base"
          >
            {data.cta.label}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
