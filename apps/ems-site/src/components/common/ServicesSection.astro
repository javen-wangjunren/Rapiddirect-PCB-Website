---
import type { EmsHomeServicesContent } from '../../types/ems-home';
import { getAssetPath, getHref } from '../../lib/assets';

export interface Props {
  data: EmsHomeServicesContent;
}

const { data } = Astro.props;
const items = Array.isArray((data as any)?.items) ? ((data as any).items as any[]) : [];
---

<section class="bg-slate-950 py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="text-4xl font-semibold tracking-tight text-slate-100 sm:text-5xl">
        {data.title}
      </h2>
      <p class="mx-auto mt-4 max-w-3xl text-sm leading-6 text-slate-400 sm:text-base">
        {data.description}
      </p>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {items.map((item) => (
        <article class="flex h-full flex-col overflow-hidden rounded-2xl bg-white shadow-[0_18px_50px_-30px_rgba(0,0,0,0.7)] ring-1 ring-black/5">
          {item.image_url ? (
            <img src={getAssetPath(item.image_url)} alt="" class="h-36 w-full object-cover" loading="lazy" decoding="async" />
          ) : (
            <div class="h-36 bg-gradient-to-br from-slate-200 to-slate-100" />
          )}
          <div class="flex flex-1 flex-col p-6">
            <h3 class="text-base font-semibold leading-6 text-slate-900">{item.name}</h3>
            {item?.description?.kind === 'paragraph' ? (
              <p class="mt-3 text-sm leading-6 text-slate-600">{item?.description?.text ?? ''}</p>
            ) : (
              <ul class="mt-3 space-y-2 text-sm leading-6 text-slate-600">
                {(Array.isArray(item?.description?.items) ? item.description.items : []).map((text: string) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-[0.45rem] h-1.5 w-1.5 flex-none rounded-full bg-[#ea543f]" />
                    <span class="min-w-0">{text}</span>
                  </li>
                ))}
              </ul>
            )}

            <div class="mt-6 pt-2">
              <a
                href={getHref(item.cta.href)}
                class="inline-flex w-full items-center justify-center rounded-xl bg-[#ea543f] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#d84c39] focus:outline-none focus:ring-2 focus:ring-[#ea543f]/50 focus:ring-offset-2"
              >
                <span>{item.cta.label}</span>
                <span class="ml-2" aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
