---
import type { PageBundle } from '../../lib/supabase/queries';
import EmsLayout from '../../layouts/EmsLayout.astro';
import HeroBanner from '../common/HeroBanner.astro';
import PcbMfgCapabilitySection from '../common/PcbMfgCapabilitySection.astro';
import PcbMfgTechTableSection from '../common/PcbMfgTechTableSection.astro';
import FaqSection from '../common/FaqSection.astro';
import QuoteFormSection from '../common/QuoteFormSection.astro';
import ApplicationAdvantageSection from '../pcb-applications/ApplicationAdvantageSection.astro';
import ApplicationDescSection from '../pcb-applications/ApplicationDescSection.astro';
import { pcbApplicationsDefaults } from '../../content/defaults/pcb-applications';
import { normalizePcbApplicationsContentJson } from '../../content/normalize/pcb-applications';
import { mergeSectionFallback } from '../../lib/supabase/mappers';
import { buildServicePageJsonLd } from '../../utils/schemaOrg';

interface Props {
  bundle: PageBundle;
  pathname: string;
}

const { bundle, pathname } = Astro.props;
const contentJson = bundle.content?.content_json ?? null;
const data = normalizePcbApplicationsContentJson(mergeSectionFallback(pcbApplicationsDefaults as any, contentJson) as any) as any;

const title = bundle.seo?.meta_title ?? `${data?.hero?.title ?? 'PCB Applications'} | RapidDirect`;
const description = bundle.seo?.meta_description ?? data?.overview?.description ?? 'PCB application-focused manufacturing and engineering support.';
const canonicalUrl = bundle.seo?.canonical_url ?? null;
const noindex = Boolean(bundle.seo?.noindex);
const applicationTitle = data?.hero?.title ?? title.replace(/\s*\|\s*RapidDirect\s*$/u, '');
const jsonLd = buildServicePageJsonLd({
  pathname,
  title,
  description,
  canonicalUrl,
  faqItems: data?.faq?.items ?? [],
  service: bundle.seo?.service_schema ?? null,
  includeBreadcrumbList: true,
  breadcrumbs: [
    { name: 'Home', path: '/' },
    { name: 'EMS', path: '/ems/' },
    { name: applicationTitle, path: pathname }
  ]
});
---

<EmsLayout title={title} description={description} canonicalUrl={canonicalUrl ?? undefined} noindex={noindex} jsonLd={jsonLd}>
  <HeroBanner data={data.hero} />
  {data.description && <ApplicationDescSection data={data.description} />}
  {data.capability && <PcbMfgCapabilitySection data={data.capability} />}
  {data.advantage && <ApplicationAdvantageSection data={data.advantage} />}
  {data.tech_table && <PcbMfgTechTableSection data={data.tech_table} variant="muted" />}
  {data.faq && <FaqSection data={data.faq} variant="white" />}
  {data.quote_form && <QuoteFormSection data={data.quote_form} />}
</EmsLayout>
