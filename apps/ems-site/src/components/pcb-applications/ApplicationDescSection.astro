---
import { getSupabaseImageUrl } from '../../lib/assets';

export interface Props {
  data: {
    header: {
      title: string;
    };
    definition: {
      lead_desc: string;
      benefits: Array<{
        title: string;
        description: string;
      }>;
      image_url?: string;
      image_alt?: string;
    };
    standards: {
      title: string;
      items: Array<{
        title: string;
        description: string;
        icon_svg: string;
      }>;
    };
    categories: {
      title: string;
      items: Array<{
        title: string;
        image_url?: string;
      }>;
    };
  };
}

const { data } = Astro.props;

// Image processing
const defImageSrc = data.definition.image_url || '';
const defImage600 = defImageSrc ? getSupabaseImageUrl(defImageSrc, { width: 600, quality: 80 }) : '';
---

<section class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center mb-12 sm:mb-16">
      <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
        {data.header.title}
      </h2>
    </div>

    <!-- Definition Split -->
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center mb-20">
      <div>
        <p class="text-lg leading-relaxed text-slate-600 mb-8">
          {data.definition.lead_desc}
        </p>
        
        <ul class="space-y-6 border-t border-slate-200 pt-8">
          {data.definition.benefits.map((benefit) => (
            <li class="flex items-start gap-4">
              <div class="mt-1 flex-shrink-0 text-[#f25537]">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <div class="text-sm sm:text-base leading-relaxed">
                <strong class="font-bold text-slate-900">{benefit.title}:</strong>
                <span class="text-slate-600"> {benefit.description}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="relative aspect-[4/3] overflow-hidden rounded-xl border border-slate-200 bg-slate-50 shadow-sm">
        {defImageSrc ? (
          <img
            src={defImage600}
            alt={data.definition.image_alt || ''}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        ) : (
          <div class="flex h-full items-center justify-center p-8 text-center text-xs font-semibold text-slate-400">
            [ Real Photo: High-reliability PCB for this application. ]
          </div>
        )}
      </div>
    </div>

    <!-- Standards Section -->
    <div class="mb-20">
      <h3 class="mb-10 text-center text-2xl font-extrabold tracking-tight text-slate-900">
        {data.standards.title}
      </h3>
      
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {data.standards.items.map((item) => (
          <div class="group rounded-xl border border-slate-200 bg-slate-50 p-8 transition-all hover:-translate-y-1 hover:border-[#f25537] hover:shadow-lg">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-[#fff5f3] text-[#f25537]">
              <Fragment set:html={item.icon_svg} />
            </div>
            <h4 class="mb-2 text-base font-extrabold text-slate-900">{item.title}</h4>
            <p class="text-sm leading-relaxed text-slate-600">{item.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Categories Section -->
    <div>
      <h3 class="mb-10 text-center text-2xl font-extrabold tracking-tight text-slate-900">
        {data.categories.title}
      </h3>
      
      <div class="grid grid-cols-2 gap-6 lg:grid-cols-3">
        {data.categories.items.map((cat) => (
          <div class="group overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-all hover:-translate-y-1 hover:border-slate-300 hover:shadow-md">
            <div class="relative aspect-[16/10] bg-slate-100">
              {cat.image_url ? (
                <img
                  src={getSupabaseImageUrl(cat.image_url, { width: 400, quality: 80 })}
                  alt={cat.title}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="flex h-full items-center justify-center p-4 text-center text-xs font-semibold text-slate-400">
                  [ {cat.title} Photo ]
                </div>
              )}
            </div>
            <div class="border-t border-slate-200 p-4 text-center">
              <h4 class="text-sm font-extrabold text-slate-900">{cat.title}</h4>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
