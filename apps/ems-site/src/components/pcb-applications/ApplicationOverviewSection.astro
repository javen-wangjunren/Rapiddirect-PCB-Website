---
export interface Props {
  data: {
    tag?: string;
    title: string;
    description: string;
    points: string[];
    cta?: { label: string; href: string };
  };
}

const { data } = Astro.props;
const points = Array.isArray(data.points) ? data.points : [];
---

<section class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-14 sm:py-18">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
      <div class="lg:col-span-5">
        {data.tag && (
          <p class="text-xs font-semibold tracking-[0.28em] text-slate-500">{data.tag}</p>
        )}
        <h2 class="mt-4 text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">{data.title}</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600 sm:text-base">{data.description}</p>

        {data.cta && data.cta.href && (
          <div class="mt-7">
            <a
              href={data.cta.href}
              class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-900/25 focus:ring-offset-2"
            >
              {data.cta.label}
            </a>
          </div>
        )}
      </div>

      <div class="lg:col-span-7">
        <div class="rounded-3xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
          <div class="grid gap-4 sm:grid-cols-2">
            {points.map((point) => (
              <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200/60">
                <div class="flex items-start gap-3">
                  <div class="mt-1 h-2.5 w-2.5 rounded-full bg-[#ea543f]" />
                  <p class="text-sm font-medium leading-6 text-slate-800">{point}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

