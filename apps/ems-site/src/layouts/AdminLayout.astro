---
import '../styles/global.css';
import '../styles/admin.css';
import AdminSidebar from '../components/admin/AdminSidebar.astro';
import AdminTopbar from '../components/admin/AdminTopbar.astro';

export interface Props {
  title?: string;
  showSidebar?: boolean;
}

const { title = 'EMS Admin', showSidebar = true } = Astro.props;
const activePath = Astro.url.pathname;
const sidebarDialogId = 'admin-sidebar-dialog';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
  </head>
  <body class="admin-shell">
    <div class="h-screen overflow-hidden min-[1200px]:flex" data-admin-shell>
      {showSidebar ? (
        <>
          <div class="admin-sidebar-slot hidden h-full min-[1200px]:block" data-admin-sidebar-slot>
            <AdminSidebar activePath={activePath} />
          </div>
          <dialog
            id={sidebarDialogId}
            class="admin-sidebar-dialog m-0 h-screen w-[min(320px,85vw)] max-w-none overflow-hidden border-0 bg-transparent p-0 backdrop:bg-black/30 min-[1200px]:hidden"
            aria-label="Sidebar menu"
            data-admin-sidebar-dialog
          >
            <div class="admin-sidebar-drawer-shell h-full">
              <AdminSidebar activePath={activePath} variant="drawer" />
            </div>
          </dialog>
        </>
      ) : null}

      <div class="min-w-0 flex-1 overflow-y-auto" data-admin-scroll-container>
        <AdminTopbar title={title} sidebarDialogId={showSidebar ? sidebarDialogId : undefined} />
        <main class="mx-auto max-w-[var(--admin-page-max)] px-[var(--admin-page-px)] py-[var(--admin-page-py)]">
          <slot />
        </main>
      </div>
    </div>

    <script is:inline>
      {String.raw`
      (() => {
        const desktopMedia = window.matchMedia('(min-width: 1200px)');
        const key = 'admin.sidebarCollapsed';
        const body = document.body;
        const sidebar = document.querySelector('.admin-sidebar[data-variant="static"]');
        const drawerSidebar = document.querySelector('.admin-sidebar[data-variant="drawer"]');
        const toggleBtn = document.querySelector('[data-admin-toggle-sidebar]');
        const openBtn = document.querySelector('[data-admin-open-sidebar]');
        const dialogId = openBtn?.getAttribute('data-admin-open-sidebar');
        const dialog = dialogId ? document.getElementById(dialogId) : null;
        const dialogEl = dialog instanceof HTMLElement ? dialog : null;
        const DialogCtor = window.HTMLDialogElement;
        const dialogDialog = DialogCtor && dialog ? (dialog instanceof DialogCtor ? dialog : null) : null;
        const supportsDialog =
          !!dialogDialog && typeof dialogDialog.showModal === 'function' && typeof dialogDialog.close === 'function';
        let lastFocusedTrigger = null;
        let desktopCollapsed = false;

        const updateToggleLabel = (collapsed) => {
          const icon = sidebar instanceof HTMLElement ? sidebar.querySelector('.admin-sidebar-toggle-icon') : null;
          const label = sidebar instanceof HTMLElement ? sidebar.querySelector('.admin-sidebar-toggle-label') : null;
          if (icon instanceof HTMLElement) icon.textContent = collapsed ? '▶' : '◀';
          if (label instanceof HTMLElement) label.textContent = collapsed ? 'Expand Menu' : 'Collapse Menu';
          if (toggleBtn instanceof HTMLElement) {
            toggleBtn.setAttribute('aria-pressed', collapsed ? 'true' : 'false');
            toggleBtn.setAttribute('aria-label', collapsed ? 'Expand sidebar' : 'Collapse sidebar');
            toggleBtn.setAttribute('title', collapsed ? 'Expand Menu' : 'Collapse Menu');
          }
        };

        const applyDesktopState = () => {
          const shouldCollapse = desktopMedia.matches && desktopCollapsed;
          body.classList.toggle('is-sidebar-collapsed', shouldCollapse);
          if (sidebar instanceof HTMLElement) {
            sidebar.classList.toggle('is-collapsed', shouldCollapse);
            sidebar.dataset.state = shouldCollapse ? 'collapsed' : 'expanded';
          }
          updateToggleLabel(shouldCollapse);
        };

        const syncDrawerState = (open) => {
          body.classList.toggle('is-admin-drawer-open', open);
          if (dialogEl) dialogEl.dataset.state = open ? 'open' : 'closed';
          if (openBtn instanceof HTMLElement) {
            openBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
            openBtn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
            openBtn.setAttribute('title', open ? 'Close menu' : 'Open menu');
          }
        };

        const focusDrawer = () => {
          if (!(drawerSidebar instanceof HTMLElement)) return;
          const firstFocusable = drawerSidebar.querySelector(
            'button:not([disabled]), a[href], [tabindex]:not([tabindex="-1"])'
          );
          if (firstFocusable instanceof HTMLElement) firstFocusable.focus();
        };

        const closeDrawer = ({ restoreFocus = true } = {}) => {
          if (!dialogEl) return;
          if (supportsDialog) {
            if (dialogDialog.open) dialogDialog.close();
          } else {
            dialogEl.removeAttribute('open');
          }
          syncDrawerState(false);
          if (restoreFocus && lastFocusedTrigger instanceof HTMLElement) {
            lastFocusedTrigger.focus();
          }
        };

        const openDrawer = () => {
          if (desktopMedia.matches || !dialogEl) return;
          if (openBtn instanceof HTMLElement) lastFocusedTrigger = openBtn;
          if (supportsDialog) {
            if (!dialogDialog.open) dialogDialog.showModal();
          } else {
            dialogEl.setAttribute('open', '');
          }
          syncDrawerState(true);
          window.requestAnimationFrame(() => {
            focusDrawer();
          });
        };

        try {
          desktopCollapsed = localStorage.getItem(key) === '1';
        } catch {}
        applyDesktopState();

        const toggleDrawer = () => {
          if (!dialogEl || desktopMedia.matches) return;
          const isOpen = supportsDialog ? dialogDialog.open : dialogEl.hasAttribute('open');
          if (isOpen) {
            closeDrawer();
          } else {
            openDrawer();
          }
        };

        const toggleDesktop = () => {
          desktopCollapsed = !desktopCollapsed;
          applyDesktopState();
          try {
            localStorage.setItem(key, desktopCollapsed ? '1' : '0');
          } catch {}
        };

        document.addEventListener(
          'click',
          (e) => {
            const target = e.target;
            if (!(target instanceof HTMLElement)) return;

            if (target.closest('[data-admin-toggle-sidebar]')) {
              e.preventDefault();
              toggleDesktop();
              return;
            }

            if (target.closest('[data-admin-open-sidebar]')) {
              e.preventDefault();
              toggleDrawer();
              return;
            }
          },
          { capture: true }
        );

        dialogEl?.addEventListener('click', (e) => {
          const target = e.target;
          if (!(target instanceof HTMLElement)) return;
          if (target === dialogEl) {
            closeDrawer();
            return;
          }
          if (target.closest('[data-admin-close-sidebar]')) {
            closeDrawer({ restoreFocus: false });
          }
        });

        if (supportsDialog) {
          dialogDialog.addEventListener('close', () => {
            syncDrawerState(false);
          });
          dialogDialog.addEventListener('cancel', (e) => {
            e.preventDefault();
            closeDrawer();
          });
        } else {
          dialogEl?.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
              e.preventDefault();
              closeDrawer();
            }
          });
        }

        const handleBreakpointChange = () => {
          if (desktopMedia.matches) {
            closeDrawer({ restoreFocus: false });
          }
          applyDesktopState();
        };
        handleBreakpointChange();

        if (typeof desktopMedia.addEventListener === 'function') {
          desktopMedia.addEventListener('change', handleBreakpointChange);
        } else if (typeof desktopMedia.addListener === 'function') {
          desktopMedia.addListener(handleBreakpointChange);
        }
      })();
      `}
    </script>
  </body>
</html>
