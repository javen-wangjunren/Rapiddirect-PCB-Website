---
import '../styles/global.css';
import SiteFooter from '../components/common/SiteFooter.astro';
import SiteHeader from '../components/common/SiteHeader.astro';
import { siteFooterDefaults } from '../content/defaults/site-footer';
import { siteHeaderDefaults } from '../content/defaults/site-header';
import { normalizeSiteFooterContentJson } from '../content/normalize/site-footer';
import { normalizeSiteHeaderContentJson } from '../content/normalize/site-header';
import { createSupabaseClient } from '../lib/supabase/client';
import { getPublishedPageBundleBySlug } from '../lib/supabase/queries';
import { deepMerge } from '../utils/jsonTree';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'RapidDirect EMS',
  description = 'EMS subsite under /ems built with Astro, React, Tailwind, and Supabase.'
} = Astro.props;

const footerSlug = '/ems/_global/footer/';
const footerSupabase = createSupabaseClient();
const footerBundle = footerSupabase ? await getPublishedPageBundleBySlug(footerSupabase, footerSlug) : null;
const footerRaw = (footerBundle?.content?.content_json ?? {}) as any;
const footerData = normalizeSiteFooterContentJson(deepMerge(siteFooterDefaults as any, footerRaw as any));

const headerSlug = '/ems/_global/header/';
const headerSupabase = createSupabaseClient();
const headerBundle = headerSupabase ? await getPublishedPageBundleBySlug(headerSupabase, headerSlug) : null;
const headerRaw = (headerBundle?.content?.content_json ?? {}) as any;
const headerData = normalizeSiteHeaderContentJson(deepMerge(siteHeaderDefaults as any, headerRaw as any));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
  </head>
  <body class="bg-slate-50 text-slate-950 antialiased">
    <div class="min-h-screen">
      <SiteHeader data={headerData as any} />

      <main>
        <slot />
      </main>

      <SiteFooter data={footerData as any} />
    </div>
  </body>
</html>
