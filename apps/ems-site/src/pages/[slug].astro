---
export const prerender = false;

import PcbApplicationsRenderer from '../components/page-renderers/PcbApplicationsRenderer.astro';
import PcbBoardManufacturingRenderer from '../components/page-renderers/PcbBoardManufacturingRenderer.astro';
import EmsLayout from '../layouts/EmsLayout.astro';
import { createSupabaseClient } from '../lib/supabase/client';
import { EMS_PREVIEW_COOKIE_NAME, isPreviewRequest } from '../lib/supabase/preview';
import { getPublishedPageBundleBySlug } from '../lib/supabase/queries';

const pathname = Astro.url.pathname;
const isPreview = isPreviewRequest(Astro.url);
const previewAccessToken = isPreview ? Astro.cookies.get(EMS_PREVIEW_COOKIE_NAME)?.value?.trim() : '';
const supabase = createSupabaseClient(previewAccessToken || undefined);
const bundle = supabase
  ? await getPublishedPageBundleBySlug(supabase, pathname, { includeDraft: Boolean(previewAccessToken) })
  : null;
const templateType = bundle?.page?.template_type ?? null;
const isPcbBoardManufacturing = templateType === 'pcb_board_manufacturing';
const isPcbApplications = templateType === 'pcb_applications';
const isFound = Boolean(bundle?.page) && (isPcbBoardManufacturing || isPcbApplications);

if (!isFound) {
  Astro.response.status = 404;
}
---

{
  isFound ? (
    isPcbApplications ? (
      <PcbApplicationsRenderer bundle={bundle!} pathname={pathname} />
    ) : (
      <PcbBoardManufacturingRenderer bundle={bundle!} pathname={pathname} />
    )
  ) : (
    <EmsLayout title="Page Not Found | RapidDirect" description="The requested EMS page could not be found." noindex={true}>
      <section class="mx-auto max-w-4xl px-6 py-24 text-center">
        <h1 class="text-3xl font-semibold tracking-tight text-slate-900">Page Not Found</h1>
        <p class="mt-4 text-base text-slate-600">
          The requested EMS page is not available at this URL.
        </p>
      </section>
    </EmsLayout>
  )
}
