---
export const prerender = false;

import { pcbBoardManufacturingDefaults } from '../content/defaults/pcb-board-manufacturing';
import HeroBanner from '../components/common/HeroBanner.astro';
import EquipmentSection from '../components/common/EquipmentSection.astro';
import FaqSection from '../components/common/FaqSection.astro';
import PcbMfgTechTableSection from '../components/common/PcbMfgTechTableSection.astro';
import QuoteFormSection from '../components/common/QuoteFormSection.astro';
import PcbBoardAdvantageSection from '../components/pcb-board-manufacturing/PcbBoardAdvantageSection.astro';
import PcbBoardIntroductionSection from '../components/pcb-board-manufacturing/PcbBoardIntroductionSection.astro';
import PcbBoardSliderSection from '../components/pcb-board-manufacturing/PcbBoardSliderSection.astro';
import PcbBoardStackupSection from '../components/pcb-board-manufacturing/PcbBoardStackupSection.astro';
import EmsLayout from '../layouts/EmsLayout.astro';
import { mergeSectionFallback } from '../lib/supabase/mappers';
import { createSupabaseClient } from '../lib/supabase/client';
import { getPublishedPageBundleBySlug } from '../lib/supabase/queries';

const slug = Astro.url.pathname;
const supabase = createSupabaseClient();
const bundle = supabase ? await getPublishedPageBundleBySlug(supabase, slug) : null;

const contentJson = bundle?.content?.content_json ?? null;
const data = mergeSectionFallback(pcbBoardManufacturingDefaults as any, contentJson) as typeof pcbBoardManufacturingDefaults;

const title = bundle?.seo?.meta_title ?? 'PCB Board Manufacturing | RapidDirect';
const description = bundle?.seo?.meta_description ?? 'PCB board manufacturing template page under /ems/pcb-board-manufacturing/.';
---

<EmsLayout title={title} description={description}>
  <HeroBanner data={data.hero} />
  <PcbBoardIntroductionSection data={data.introduction} />
  <PcbBoardStackupSection data={(data as any).stackup} />
  <PcbBoardAdvantageSection data={data.advantage} />
  <PcbMfgTechTableSection data={(data as any).tech_table} variant="muted" />
  <PcbBoardSliderSection data={(data as any).slider} />
  <EquipmentSection data={(data as any).equipment} variant="muted" />
  <FaqSection data={(data as any).faq} />
  <QuoteFormSection data={(data as any).quote_form} />
</EmsLayout>
