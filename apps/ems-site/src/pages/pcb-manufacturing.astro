---
export const prerender = false;

import EmsLayout from '../layouts/EmsLayout.astro';
import HeroBanner from '../components/common/HeroBanner.astro';
import PcbMfgCapabilitySection from '../components/pcb-manufacturing/PcbMfgCapabilitySection.astro';
import PcbMfgTechTableSection from '../components/pcb-manufacturing/PcbMfgTechTableSection.astro';
import QualityControlSection from '../components/common/QualityControlSection.astro';
import IndustrySection from '../components/common/IndustrySection.astro';
import WhyChooseUsSection from '../components/common/WhyChooseUsSection.astro';
import ProductGallerySection from '../components/common/ProductGallerySection.astro';
import FaqSection from '../components/common/FaqSection.astro';
import QuoteFormSection from '../components/common/QuoteFormSection.astro';
import { pcbManufacturingDefaults } from '../content/defaults/pcb-manufacturing';
import { normalizePcbManufacturingContentJson } from '../content/normalize/pcb-manufacturing';
import { createSupabaseClient } from '../lib/supabase/client';
import { mergeSectionFallback } from '../lib/supabase/mappers';
import { getPublishedPageBundleBySlug } from '../lib/supabase/queries';

const slug = Astro.url.pathname;
const supabase = createSupabaseClient();
const bundle = supabase ? await getPublishedPageBundleBySlug(supabase, slug) : null;

const contentJson = bundle?.content?.content_json ?? null;
const data = normalizePcbManufacturingContentJson(mergeSectionFallback(pcbManufacturingDefaults as any, contentJson) as any) as any;

const title = bundle?.seo?.meta_title ?? 'PCB Manufacturing | RapidDirect';
const description = bundle?.seo?.meta_description ?? 'PCB manufacturing service page under /ems/pcb-manufacturing/.';
---

<EmsLayout title={title} description={description}>
  <HeroBanner data={data.hero} />
  <PcbMfgCapabilitySection data={data.capability} />
  <PcbMfgTechTableSection data={data.tech_table} />
  <QualityControlSection data={data.quality} />
  <IndustrySection data={data.industry} />
  <WhyChooseUsSection data={data.why_choose_us} />
  <ProductGallerySection data={data.product_gallery} />
  <FaqSection data={data.faq} />
  <QuoteFormSection data={data.quote_form} />
</EmsLayout>
