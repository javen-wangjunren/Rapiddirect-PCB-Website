---
export const prerender = false;

import { pcbBoardManufacturingDefaults } from '../../content/defaults/pcb-board-manufacturing';
import PcbBoardManufacturingPage from '../../components/pcb-board-manufacturing/PcbBoardManufacturingPage.astro';
import { mergeSectionFallback } from '../../lib/supabase/mappers';
import { createSupabaseClient } from '../../lib/supabase/client';
import { getPublishedPageBundleBySlug } from '../../lib/supabase/queries';
import { buildServicePageJsonLd } from '../../utils/schemaOrg';

const slug = Astro.url.pathname;
const supabase = createSupabaseClient();
const bundle = supabase ? await getPublishedPageBundleBySlug(supabase, slug) : null;

const contentJson = bundle?.content?.content_json ?? null;
const data = mergeSectionFallback(pcbBoardManufacturingDefaults as any, contentJson) as typeof pcbBoardManufacturingDefaults;

const title = bundle?.seo?.meta_title ?? 'PCB Board Manufacturing | RapidDirect';
const description =
  bundle?.seo?.meta_description ?? 'PCB manufacturing detail page under /ems/pcb-manufacturing/.';
const canonicalUrl = bundle?.seo?.canonical_url ?? null;
const noindex = Boolean(bundle?.seo?.noindex);
const detailTitle = data?.hero?.title ?? title.replace(/\s*\|\s*RapidDirect\s*$/u, '');
const jsonLd = buildServicePageJsonLd({
  pathname: Astro.url.pathname,
  title,
  description,
  canonicalUrl,
  faqItems: data?.faq?.items ?? [],
  service: bundle?.seo?.service_schema ?? null,
  includeBreadcrumbList: true,
  breadcrumbs: [
    { name: 'Home', path: '/' },
    { name: 'EMS', path: '/ems/' },
    { name: 'PCB Manufacturing', path: '/ems/pcb-manufacturing/' },
    { name: detailTitle, path: Astro.url.pathname }
  ]
});
---

<PcbBoardManufacturingPage
  title={title}
  description={description}
  canonicalUrl={canonicalUrl ?? undefined}
  noindex={noindex}
  jsonLd={jsonLd}
  data={data}
/>

